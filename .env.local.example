# Supabase — create a project at https://supabase.com/dashboard
# Project Settings → API: copy URL and anon (public) key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Project Settings → API → service_role (server-only, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI providers (server-only — set in Vercel for production)
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# Webhook signature secrets (server-only)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
SHIPPO_API_KEY=your-shippo-api-token
# SHIPPO_WEBHOOK_SECRET=         # set when HMAC configured with Shippo

# Stripe — dedicated TradeFlow account (test keys shown; server-only)
# Dashboard → Developers → API keys: Secret key (sk_test_...)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Dashboard → Developers → Webhooks → your endpoint: Signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
